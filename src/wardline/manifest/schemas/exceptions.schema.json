{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://wardline.dev/schemas/0.1/exceptions.schema.json",
  "title": "Wardline Exception Register",
  "description": "Granted exceptions to wardline rule findings.",
  "type": "object",
  "properties": {
    "$id": {
      "type": "string",
      "description": "Schema version identifier."
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique exception identifier."
          },
          "rule": {
            "type": "string",
            "description": "Rule ID this exception applies to."
          },
          "taint_state": {
            "type": "string",
            "enum": [
              "AUDIT_TRAIL", "PIPELINE", "SHAPE_VALIDATED",
              "EXTERNAL_RAW", "UNKNOWN_RAW",
              "UNKNOWN_SHAPE_VALIDATED", "UNKNOWN_SEM_VALIDATED",
              "MIXED_RAW"
            ]
          },
          "location": {
            "type": "string",
            "description": "File path and line of the excepted finding."
          },
          "exceptionability": {
            "type": "string",
            "enum": ["STANDARD", "RELAXED", "TRANSPARENT"]
          },
          "severity_at_grant": {
            "type": "string",
            "enum": ["ERROR", "WARNING", "SUPPRESS"]
          },
          "rationale": {
            "type": "string",
            "description": "Why this exception was granted."
          },
          "reviewer": {
            "type": "string",
            "description": "Who approved this exception."
          },
          "expires": {
            "type": ["string", "null"],
            "format": "date",
            "description": "Expiry date (ISO 8601). Null for no expiry."
          },
          "provenance": {
            "type": ["string", "null"],
            "description": "How this exception was created."
          },
          "agent_originated": {
            "type": ["boolean", "null"],
            "description": "Whether this exception was authored by an AI agent. Null means provenance unknown."
          },
          "recurrence_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Times this (rule, location) exception has been renewed."
          },
          "governance_path": {
            "type": "string",
            "enum": ["standard", "expedited"],
            "description": "Governance path used to grant this exception."
          },
          "ast_fingerprint": {
            "type": "string",
            "description": "16-char hex SHA-256 fingerprint of the function AST. Empty means always stale."
          },
          "last_refreshed_by": {
            "type": ["string", "null"],
            "description": "Who last refreshed this exception's fingerprint."
          },
          "last_refresh_rationale": {
            "type": ["string", "null"],
            "description": "Rationale for the last fingerprint refresh."
          },
          "last_refreshed_at": {
            "type": ["string", "null"],
            "format": "date",
            "description": "When the fingerprint was last refreshed (ISO 8601)."
          }
        },
        "required": [
          "id", "rule", "taint_state", "location",
          "exceptionability", "severity_at_grant",
          "rationale", "reviewer"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": ["exceptions"],
  "additionalProperties": false
}
