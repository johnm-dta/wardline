{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://wardline.dev/schemas/0.1/fingerprint.schema.json",
  "title": "Wardline Annotation Fingerprint",
  "description": "Per-function annotation hash records for baseline tracking.",
  "type": "object",
  "properties": {
    "$id": {
      "type": "string",
      "description": "Schema version identifier."
    },
    "python_version": {
      "type": "string",
      "description": "Python major.minor version used for fingerprint computation."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the baseline was generated."
    },
    "coverage": {
      "type": "object",
      "properties": {
        "annotated": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of annotated functions."
        },
        "total": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of functions."
        },
        "ratio": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Ratio of annotated to total functions."
        },
        "tier1_annotated": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of annotated functions in tier 1."
        },
        "tier1_total": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of functions in tier 1."
        },
        "tier1_unannotated": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Qualnames of unannotated tier 1 functions."
        }
      },
      "required": ["annotated", "total", "ratio", "tier1_annotated", "tier1_total"],
      "additionalProperties": false
    },
    "fingerprints": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "qualified_name": {
            "type": "string",
            "description": "Fully qualified function name."
          },
          "module": {
            "type": "string",
            "description": "Module containing the function."
          },
          "decorators": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Wardline decorator canonical names applied."
          },
          "annotation_hash": {
            "type": "string",
            "minLength": 16,
            "pattern": "^[0-9a-f]{16,64}$",
            "description": "SHA-256 hash of the normalised annotation (minimum 16 hex chars / 64 bits)."
          },
          "tier_context": {
            "type": "integer",
            "minimum": 1,
            "maximum": 4,
            "description": "Authority tier context of this function."
          },
          "boundary_transition": {
            "type": ["string", "null"],
            "description": "Boundary transition type, if any."
          },
          "last_changed": {
            "type": ["string", "null"],
            "format": "date",
            "description": "Date of last annotation change."
          },
          "artefact_class": {
            "type": "string",
            "enum": ["policy", "enforcement", ""],
            "description": "Artefact classification: policy (tier/boundary) or enforcement (supplementary)."
          }
        },
        "required": [
          "qualified_name", "module", "decorators",
          "annotation_hash", "tier_context"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": ["fingerprints"],
  "additionalProperties": false
}
